<Window x:Class="DirectoryCopier.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DirectoryCopier.ViewModels"
        xmlns:conv="clr-namespace:DirectoryCopier.Converters"
        mc:Ignorable="d"
        Title="Копирование директорий (MVVM)" Height="700" Width="900"
        Background="Black" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:LogColorConverter x:Key="LogColorConverter"/>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <conv:BytesToStringConverter x:Key="BytesToStringConverter"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,5,10,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#222222"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="КОПИРОВАНИЕ ДИРЕКТОРИЙ" 
                   FontSize="24" FontWeight="Bold" Foreground="White" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Source Path -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Источник:" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" 
                     Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" 
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Обзор..." Style="{StaticResource ButtonStyle}" 
                    Command="{Binding BrowseSourceCommand}"/>
        </Grid>

        <!-- Destination Path -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Назначение:" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" 
                     Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}" 
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Обзор..." Style="{StaticResource ButtonStyle}" 
                    Command="{Binding BrowseDestinationCommand}"/>
        </Grid>

        <!-- Thread Count -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Потоки:" Style="{StaticResource LabelStyle}"/>
            <Slider Grid.Column="1" Minimum="1" Maximum="16" Value="{Binding ThreadCount, UpdateSourceTrigger=PropertyChanged}" 
                    VerticalAlignment="Center" Margin="10,0" Foreground="White"/>
            <TextBlock Grid.Column="2" Text="{Binding ThreadCount}" Style="{StaticResource InfoStyle}" 
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Width="30"/>
        </Grid>

        <!-- Progress -->
        <Border Grid.Row="4" Background="Black" BorderBrush="White" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding Status}" Style="{StaticResource InfoStyle}" 
                           HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                <ProgressBar Grid.Row="1" Height="25" Value="{Binding ProgressValue}" Minimum="0" Maximum="100"
                             Background="#333333" Foreground="White" 
                             BorderThickness="0" Margin="0,0,0,5"/>
                <TextBlock Grid.Row="2" Text="{Binding ProgressText}" Style="{StaticResource InfoStyle}" 
                           HorizontalAlignment="Center" FontSize="14"/>
                <TextBlock Grid.Row="3" Text="{Binding CurrentFile}" Style="{StaticResource InfoStyle}" 
                           HorizontalAlignment="Center" FontSize="12" Foreground="#cccccc" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- Log -->
        <Border Grid.Row="5" Background="Black" BorderBrush="White" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Журнал событий" Style="{StaticResource InfoStyle}" 
                           FontWeight="Bold" Margin="0,0,0,5"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Message}" 
                                           Foreground="{Binding Type, Converter={StaticResource LogColorConverter}}"
                                           FontSize="12" TextWrapping="Wrap" Margin="2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Старт" Style="{StaticResource ButtonStyle}" 
                    Command="{Binding StartCommand}" Width="120"/>
            <Button Content="Отмена" Style="{StaticResource ButtonStyle}" 
                    Command="{Binding CancelCommand}" Background="#222222"/>
        </StackPanel>
    </Grid>
</Window>
